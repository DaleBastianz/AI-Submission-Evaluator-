generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id          String   @id @default(cuid())
  name        String
  email       String
  title       String
  type        String
  contentText String?
  fileUrl     String?
  link        String?
  aiScore     Int?
  aiGrade     String?
  aiFeedback  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
